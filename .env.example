# Copy this file to .env.local and fill in your Xano API group URLs.
# Find these in Xano → your workspace → API Groups → each group's base URL.

NEXT_PUBLIC_XANO_SURVEY_API=https://YOUR-INSTANCE.e2.xano.io/api:SURVEY_GROUP_ID
NEXT_PUBLIC_XANO_AUTH_API=https://YOUR-INSTANCE.e2.xano.io/api:AUTH_GROUP_ID
NEXT_PUBLIC_XANO_DASH_API=https://YOUR-INSTANCE.e2.xano.io/api:DASHBOARD_GROUP_ID
